# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/meetory

# JWT
JWT_SECRET=meetory_super_secret_key_change_in_production
JWT_REFRESH_SECRET=meetory_refresh_secret_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Client
CLIENT_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# File Upload (Max 10MB)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Cloudinary Credentials (Optional - Local fallback will be used if keys are absent)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
